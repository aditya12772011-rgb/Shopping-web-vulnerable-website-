from flask import Flask, render_template_string, request, jsonify

app = Flask(__name__)

# Sample products
products = [
    {"id": 1, "name": "Product 1", "price": 19.99},
    {"id": 2, "name": "Product 2", "price": 29.99},
    {"id": 3, "name": "Product 3", "price": 39.99},
]

cart = []

# Main route with embedded HTML, CSS, JS
@app.route('/')
def index():
    html_content = '''
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Fake Amazon - Vulnerability Testing</title>
<style>
body {
  font-family: Arial, sans-serif;
  margin: 0;
  padding: 0;
}
header {
  background-color: #232f3e;
  color: white;
  padding: 10px;
  display: flex;
  align-items: center;
}
#menuBtn {
  font-size: 24px;
  background: none;
  border: none;
  color: white;
  cursor: pointer;
  margin-right: 10px;
}
#menu.hidden {
  display: none;
}
nav#menu {
  background-color: #37475a;
  padding: 10px;
}
nav#menu ul {
  list-style: none;
  padding: 0;
}
nav#menu ul li {
  margin: 5px 0;
}
.product-list {
  display: flex;
  flex-wrap: wrap;
  padding: 20px;
}
.product {
  border: 1px solid #ccc;
  padding: 10px;
  margin: 10px;
  width: 200px;
}
.cart {
  padding: 20px;
  background-color: #f4f4f4;
}
</style>
</head>
<body>
<header>
  <button id="menuBtn">☰</button>
  <h1>Fake Amazon</h1>
</header>
<nav id="menu" class="hidden">
  <ul>
    <li><a href="#">Home</a></li>
    <li><a href="#">Products</a></li>
    <li><a href="#">Cart (<span id="cartCount">0</span>)</a></li>
  </ul>
</nav>
<main>
  <section class="product-list">
    {% for product in products %}
    <div class="product">
      <h2>{{ product.name }}</h2>
      <p>Price: ${{ product.price }}</p>
      <button class="buyBtn" data-id="{{ product.id }}">Buy</button>
    </div>
    {% endfor %}
  </section>
  <section class="cart">
    <h2>Your Cart</h2>
    <ul id="cartItems"></ul>
    <button id="checkoutBtn">Checkout</button>
  </section>
</main>
<script>
document.addEventListener('DOMContentLoaded', () => {
  const menuBtn = document.getElementById('menuBtn');
  const menu = document.getElementById('menu');
  const cartCountSpan = document.getElementById('cartCount');
  const cartItemsUl = document.getElementById('cartItems');

  let cart = [];

  // Toggle menu
  menuBtn.addEventListener('click', () => {
    menu.classList.toggle('hidden');
  });

  // Add to cart
  document.querySelectorAll('.buyBtn').forEach(btn => {
    btn.addEventListener('click', () => {
      const productId = parseInt(btn.dataset.id);
      fetch('/add_to_cart', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({product_id: productId})
      })
      .then(res => res.json())
      .then(data => {
        if (data.status === 'success') {
          cart = data.cart;
          updateCart();
        }
      });
    });
  });

  function updateCart() {
    cartCountSpan.textContent = cart.length;
    // Update cart list
    cartItemsUl.innerHTML = '';
    cart.forEach(item => {
      const li = document.createElement('li');
      li.textContent = item.name + ' - $' + item.price;
      cartItemsUl.appendChild(li);
    });
  }

  // Optional checkout
  document.getElementById('checkoutBtn').addEventListener('click', () => {
    alert('Checkout feature coming soon!');
  });
});
</script>
</body>
</html>
    '''
    return render_template_string(html_content, products=products)

@app.route('/add_to_cart', methods=['POST'])
def add_to_cart():
    data = request.get_json()
    product_id = data.get('product_id')
    product = next((p for p in products if p['id'] == product_id), None)
    if product:
        cart.append(product)
        return jsonify({"status": "success", "cart": cart})
    return jsonify({"status": "error"}), 400

if __name__ == '__main__':
    app.run(debug=True)