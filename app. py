# --- Directories (Routes) Configuration ---

@app.route('/')
def home():
    return render_template_string(HOME_TEMPLATE)

@app.route('/checkout')
def checkout():
    # Gets the item name from URL (e.g., /checkout?item=Notebook)
    item_name = request.args.get('item', 'Product')
    return render_template_string(CHECKOUT_TEMPLATE, item_name=item_name)

@app.route('/admin-login', methods=['GET', 'POST'])
def admin_login():
    error = None
    if request.method == 'POST':
        username = request.form['username']
        password = request.form['password']
        
        if username == ADMIN_USER and password == ADMIN_PASS:
            return "<h1>🎉 Success! Admin Dashboard Unlocked.</h1>"
        else:
            error = "Invalid credentials!"
            
    return render_template_string(LOGIN_TEMPLATE, error=error)

if __name__ == '__main__':
    app.run(host='127.0.0.1', port=5000)
